# Never put a Qualcomm API token here. Use:
# qai-hub configure --api_token YOUR_API_TOKEN

# A value of 1 is one way to authorize remote jobs; --run-remote is the other.
QAIHUB_RUN_REMOTE=0

# Optional cache overrides.
QAIHUB_BENCH_CACHE=
HF_HOME=
TORCH_HOME=

# Optional Hugging Face authentication for gated custom VLMs.
HF_TOKEN=
